provider:
  - name: deepseek
    api_key: "your_deepseek_api_key_here"
    base_url: "https://api.deepseek.com"
  - name: dashscope
    api_key: "your_dashscope_api_key_here"
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"

models:
  - name: deepseek-v4-pro
    provider: deepseek
    context: 1048576
    vision: false
  - name: deepseek-v4-flash
    provider: deepseek
    context: 65536
    vision: false

system_prompt: "You are a helpful assistant. Answer based on the provided content."
default_model: "deepseek-v4-pro"

ocr:
  language: "ch"
  device: "cpu"

hotkeys:
  screenshot: "ctrl+shift+left"
  toggle_overlay: "ctrl+alt+a"
  move_overlay: "ctrl+shift+right"

output_window:
  position:
    x: 100
    y: 100
  size:
    width: 600
    height: 400
  font:
    family: "Microsoft YaHei"
    size: 14
    color: "#FFFFFF"
  shadow: true

systray:
  show_icon: true

knowledge:
  enabled: true
  directory: "knowledge"
  memory_directory: "memory"
