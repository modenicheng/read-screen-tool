provider:
  - name: deepseek
    api_key: "sk-..."
    base_url: "https://api.deepseek.com"
  - name: dashscope
    api_key: "sk-..."
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"

models:
  - name: deepseek-v4-pro
    provider: deepseek
    context: 1048576
    vision: false
  - name: qwen3.6-plus
    provider: dashscope
    context: 1048576
    vision: true
  - name: qwen3.6-flash
    provider: dashscope
    context: 1048576
    vision: true

system_prompt:
  You are a helpful assistant. Answer based on the provided content. If the content is insufficient, say you don't know.
  Always be concise. Use Chinese to answer.

# default_model: "qwen3.6-plus"
# default_model: "qwen3.6-flash"
default_model: "deepseek-v4-pro"

ocr:
  language: "ch"
  device: "gpu"

hotkeys:
  screenshot: "ctrl+alt+left"
  toggle_overlay: "ctrl+alt+a"
  move_overlay: "ctrl+alt+right"

output_window:
  position:
    x: 100
    y: 100
  size:
    width: 400
    height: 600
  font:
    family: "Microsoft YaHei"
    size: 12
    color: "#FFFFFF"
  shadow: false

systray:
  show_icon: true

knowledge:
  enabled: true
  directory: "knowledge"
